    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-query": "^5.100.14",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/yup": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
